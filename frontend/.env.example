# Optional. In dev, requests to /api are proxied to VITE_API_TARGET (default
# http://localhost:8000). In production on Vercel, /api is rewritten to the
# backend via vercel.json, so this is usually left unset.
VITE_API_TARGET=http://localhost:8000
# Override the API base path directly (e.g. a full backend URL). Defaults to /api.
# VITE_API_BASE=/api
