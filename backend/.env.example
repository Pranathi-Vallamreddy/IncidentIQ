# Copy to .env and fill in. All optional — the app runs fully without any of these.

# Gemini API key. If unset, the app uses the deterministic explainer.
GEMINI_API_KEY=

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173

# SQLite database URL.
DATABASE_URL=sqlite:///./incidentiq.db
