# Copy to .env and fill in. All optional — the app runs fully without any of these.

# Gemini API key. If unset, the app uses the deterministic explainer.
GEMINI_API_KEY=
# Gemini model id (optional). Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of explicitly allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173
# Regex of allowed origins (in addition to the list above). Defaults to any
# *.vercel.app deployment so the frontend works without pinning its exact URL.
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# SQLite database URL.
DATABASE_URL=sqlite:///./incidentiq.db
